# Crawlers Environment Variables
# Copy this file to .env and update the values

# =============================================================================
# LinkedIn Configuration
# =============================================================================
# LinkedIn credentials for scraping
LINKEDIN_USERNAME=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# LinkedIn API (optional)
LINKEDIN_API_KEY=your_linkedin_api_key
LINKEDIN_API_SECRET=your_linkedin_api_secret

# =============================================================================
# Proxy Configuration (optional)
# =============================================================================
# Use a proxy to avoid IP blocking
PROXY_URL=http://your-proxy:port
PROXY_USERNAME=your_proxy_username
PROXY_PASSWORD=your_proxy_password

# =============================================================================
# API Configuration
# =============================================================================
# Backend API URL for storing scraped data
API_URL=http://backend:8000
API_KEY=your_api_key

# =============================================================================
# Database Configuration
# =============================================================================
# For direct database access (optional)
DATABASE_URL=postgresql://postgres:postgres@db:5432/bazov

# =============================================================================
# Crawler Settings
# =============================================================================
# Delay between requests (in seconds)
REQUEST_DELAY=1

# Maximum concurrent requests
MAX_CONCURRENT_REQUESTS=5

# User agent
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Debug mode
DEBUG=true

# =============================================================================
# News Sources
# =============================================================================
# RSS feeds and news sources to scrape
NEWS_SOURCES=https://techcrunch.com/feed,https://news.ycombinator.com/rss,https://blog.google/feed

# News API (optional)
NEWS_API_KEY=your_news_api_key
